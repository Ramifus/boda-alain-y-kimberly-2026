---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";

// Importar la PORTADA primero
import Portada from "../components/Portada.astro";

import NombresFlores from "../components/NombresFlores.astro";
import Fecha from "../components/Fecha.astro";
import Contador from "../components/Contador.astro";
import Pase from "../components/Pase.astro";
import Nombres from "../components/Nombres.astro";
import DireccionIglesia from "../components/DireccionIglesia.astro";
import DireccionCivil from "../components/DireccionCivil.astro";
import DireccionRecepcion from "../components/DireccionRecepcion.astro";
import DressCode from "../components/DressCode.astro";
import Itinerario from "../components/Itinerario.astro";
import CompartirFotos from "../components/CompartirFotos.astro";
import Restringir from "../components/Restringir.astro";
import SugerenciaRegalo from "../components/SugerenciaRegalo.astro";
import ConfirmarAsistencia from "../components/ConfirmarAsistencia.astro";
import Despedida from "../components/Despedida.astro";
import Galeria from "../components/Galeria.astro";
import Pase2 from "../components/pase2.astro";
import Reproductor from "../components/Reproductor.astro";
---

<Layout title="Mi Boda">
    <!-- 🎊 PORTADA DE BIENVENIDA (se muestra primero) -->
    <Portada />
    <!-- <Reproductor/> -->
    <!-- 📋 RESTO DE COMPONENTES (se muestran después de presionar INGRESAR) -->
    <NombresFlores />
    <Fecha />
    <Contador />
    <Pase2 />
    <!-- <Pase/> -->
    <Nombres />
    <DireccionIglesia />
    <DireccionCivil />
    <DireccionRecepcion />
    <DressCode />
    <Galeria />
    <!-- <Itinerario/> -->
    <!-- <CompartirFotos/> -->
    <Restringir />
    <SugerenciaRegalo />

    <ConfirmarAsistencia />
    <Despedida />
</Layout>
