---
// ComponenteSugerenciaRegalo.astro
---

<section class="relative bg-[#6B7154] w-full py-16 px-6">
    <div class="max-w-2xl mx-auto">
        <!-- Título "Sugerencia de Regalo" -->
        <div id="titulo-regalo" class="text-center mb-8">
            <h3
                class="font-great-vibes text-5xl sm:text-6xl md:text-7xl text-[#C9A961] tracking-wides leading-16"
            >
                Sugerencia de Regalo
            </h3>
        </div>

        <!-- Texto explicativo -->
        <div id="texto-explicativo" class="text-center mb-10">
            <p
                class="text-white text-sm sm:text-base md:text-lg font-serif leading-relaxed"
            >
                El mejor regalo es su presencia; sin embargo, si desean tener un
                detalle con nosotros, pueden hacerlo mediante el código QR.
            </p>
        </div>

        <!-- Imagen QR -->
        <div id="tarjeta-qr" class="flex flex-col items-center text-center">
            <div class="w-64 h-64 sm:w-80 sm:h-80 mb-6 bg-white rounded-lg p-2">
                <img
                    src="/imagenes/qr.png"
                    alt="Código QR"
                    class="w-full h-full object-contain"
                />
            </div>

            <!-- Detalles de la cuenta -->
            <div class="text-white font-serif text-sm sm:text-base space-y-1">
                <p>
                    <span class="text-[#C9A961]">Nombre:</span> Kimberly Leon Rodriguez
                </p>
                <p>
                    <span class="text-[#C9A961]">Nro. cuenta:</span> 1008568932
                </p>
                <p>
                    <span class="text-[#C9A961]">Concepto:</span> Boda Alain y Kim
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        console.log("🎁 Iniciando animaciones de sugerencia de regalo...");

        // ═══ TÍTULO "SUGERENCIA DE REGALO" ═══
        gsap.fromTo(
            "#titulo-regalo",
            { opacity: 0, y: -30 },
            {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#titulo-regalo",
                    start: "top 80%",
                    once: true,
                },
            },
        );

        // ═══ TEXTO EXPLICATIVO ═══
        gsap.fromTo(
            "#texto-explicativo",
            { opacity: 0, y: 20 },
            {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#texto-explicativo",
                    start: "top 80%",
                    once: true,
                },
                delay: 0.3,
            },
        );

        // ═══ TARJETA DE QR ═══
        gsap.fromTo(
            "#tarjeta-qr",
            { opacity: 0, x: 50, scale: 0.9 },
            {
                opacity: 1,
                x: 0,
                scale: 1,
                duration: 0.8,
                ease: "back.out(1.4)",
                scrollTrigger: {
                    trigger: "#tarjeta-qr",
                    start: "top 80%",
                    once: true,
                },
                delay: 0.7,
            },
        );

        console.log("✨ Animaciones de sugerencia de regalo completadas!");
    });
</script>

<style>
    /* Transiciones suaves en la tarjeta */
    #tarjeta-qr {
        transition: all 0.3s ease;
    }

    /* Efecto hover en el título */
    #titulo-regalo:hover {
        transform: scale(1.05);
        transition: transform 0.3s ease;
    }
</style>
